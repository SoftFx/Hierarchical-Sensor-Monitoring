@model string

@{
    var nodeId = Model;
    var graphId = $"graph_node_{nodeId}";
    var dataUrl = Url.Action("NodeChartHistory", "SensorHistory");
}

<div class="pt-3" id="nodeChartData_@nodeId" data-url="@dataUrl" data-node-id="@nodeId">
    <div class="d-flex align-items-center gap-2 flex-wrap">
        <label class="m-0">Period:</label>
        <select class="form-select" style="width: auto;" id="nodeChartPeriod_@nodeId"
                onchange="onNodeChartPeriodChange('@nodeId')">
            <option value="hour" selected>Last hour</option>
            <option value="threeHours">Last 3 hours</option>
            <option value="day">Last day</option>
            <option value="custom">Custom</option>
        </select>

        <div id="nodeChartTypeWrap_@nodeId" class="d-none align-items-center gap-2">
            <label class="m-0" for="nodeChartType_@nodeId">Type:</label>
            <select class="form-select" style="width: auto;" id="nodeChartType_@nodeId"
                    onchange="loadNodeChart('@nodeId')"></select>
        </div>

        <div id="nodeChartCustom_@nodeId" class="d-none align-items-center gap-2">
            <label class="m-0" for="nodeChartFrom_@nodeId">From:</label>
            <input type="datetime-local" class="form-control" style="width: auto;" id="nodeChartFrom_@nodeId">
            <label class="m-0" for="nodeChartTo_@nodeId">To:</label>
            <input type="datetime-local" class="form-control" style="width: auto;" id="nodeChartTo_@nodeId">
            <button type="button" class="btn btn-secondary" onclick="loadNodeChart('@nodeId')">
                <i class="fas fa-search"></i>
            </button>
        </div>
    </div>

    <div class="mt-1 text-muted" style="font-size: 0.85em;">
        One line per comparable child sensor. Sensors with no data in the window are omitted, and
        intermittent series (e.g. top-N processes reported only while active) are drawn with gaps.
    </div>

    <div id="nodeChartNote_@nodeId" class="mt-1 d-none" style="color: #b8860b; font-size: 0.85em;"></div>

    <div id="nodeChartNoData_@nodeId" class="d-none d-flex justify-content-center align-items-center noData-label mt-2">
        <label>No data for the selected period</label>
    </div>

    <div class="mt-2" id="@graphId" style="width: 100%; height: 450px;"></div>
</div>

<script>
    (function () {
        // 20 distinct colors — matches the server-side MaxSensorsPerChart cap so lines don't repeat.
        const nodeChartPalette = [
            '#1f77b4', '#ff7f0e', '#2ca02c', '#d62728', '#9467bd', '#8c564b',
            '#e377c2', '#17becf', '#bcbd22', '#7f7f7f', '#393b79', '#e7ba52',
            '#843c39', '#5254a3', '#637939', '#a55194', '#3182bd', '#b5cf6b',
            '#ce6dbd', '#e7969c'
        ];

        // Show (as inline-flex) or hide a control group.
        function setInlineFlex(el, show) {
            el.classList.toggle('d-none', !show);
            el.classList.toggle('d-flex', show);
        }

        window.onNodeChartPeriodChange = function (nodeId) {
            const isCustom = document.getElementById(`nodeChartPeriod_${nodeId}`).value === 'custom';
            setInlineFlex(document.getElementById(`nodeChartCustom_${nodeId}`), isCustom);

            if (!isCustom)
                loadNodeChart(nodeId);
        };

        // Interpret a datetime-local value ("YYYY-MM-DDTHH:MM", or "...:SS" in some browsers) as UTC.
        // Falls back on empty or unparseable input so toISOString() can never throw on Invalid Date.
        function parseLocalAsUtc(value, fallback) {
            if (!value)
                return fallback;

            const parsed = new Date(value.length <= 16 ? `${value}:00Z` : `${value}Z`);
            return isNaN(parsed.getTime()) ? fallback : parsed;
        }

        function nodeChartWindow(nodeId) {
            const period = document.getElementById(`nodeChartPeriod_${nodeId}`).value;
            const now = new Date();

            if (period === 'custom') {
                const fromVal = document.getElementById(`nodeChartFrom_${nodeId}`).value;
                const toVal = document.getElementById(`nodeChartTo_${nodeId}`).value;
                // datetime-local carries no timezone; interpret as UTC to match server-stored times.
                const from = parseLocalAsUtc(fromVal, new Date(now.getTime() - 3600e3));
                const to = parseLocalAsUtc(toVal, now);
                return { from: from.toISOString(), to: to.toISOString() };
            }

            const spans = { hour: 3600e3, threeHours: 3 * 3600e3, day: 24 * 3600e3 };
            return { from: new Date(now.getTime() - spans[period]).toISOString(), to: now.toISOString() };
        }

        // Called from the Chart tab link (onclick), the period selector, and the group selector.
        window.loadNodeChart = function (nodeId) {
            const container = document.getElementById(`nodeChartData_${nodeId}`);
            if (!container)
                return;

            const { from, to } = nodeChartWindow(nodeId);
            const typeSel = document.getElementById(`nodeChartType_${nodeId}`);
            const groupKey = typeSel ? typeSel.value : '';
            // Per-node request token: a newer request for THIS node supersedes its own older ones, but
            // charts for other open nodes don't cancel each other (a single global counter did, blanking
            // whichever node's response arrived after another node's request started).
            const token = String((Number(container.dataset.reqToken) || 0) + 1);
            container.dataset.reqToken = token;

            $.ajax({
                type: 'POST',
                url: container.dataset.url,
                contentType: 'application/json',
                dataType: 'json',
                cache: false,
                data: JSON.stringify({ nodeId: container.dataset.nodeId, from: from, to: to, groupKey: groupKey })
            }).done(function (data) {
                if (token !== container.dataset.reqToken)
                    return;
                renderNodeChart(nodeId, data);
            }).fail(function () {
                if (token !== container.dataset.reqToken)
                    return;
                showNodeChartMessage(nodeId, 'Failed to load chart data');
            });
        };

        // Show a centered message (no data / error) and clear the chart + note.
        function showNodeChartMessage(nodeId, message) {
            const graphEl = document.getElementById(`graph_node_${nodeId}`);
            const noData = document.getElementById(`nodeChartNoData_${nodeId}`);
            const noteEl = document.getElementById(`nodeChartNote_${nodeId}`);

            if (graphEl && window.Plotly)
                window.Plotly.purge(graphEl);
            if (noteEl)
                noteEl.classList.add('d-none');
            if (noData) {
                const label = noData.querySelector('label');
                if (label)
                    label.textContent = message;
                noData.classList.remove('d-none');
            }
        }

        function nodeChartEscape(s) {
            return String(s).replace(/[&<>"']/g, function (c) {
                return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
            });
        }

        // Populate the "Type" group selector from the response; shown only when the node has >1 group.
        function updateNodeChartTypes(nodeId, data) {
            const wrap = document.getElementById(`nodeChartTypeWrap_${nodeId}`);
            const sel = document.getElementById(`nodeChartType_${nodeId}`);
            const groups = (data && data.groups) || [];

            if (!wrap || !sel)
                return;

            if (groups.length > 1) {
                const sig = groups.map(function (g) { return g.key; }).join('|');
                if (sel.dataset.sig !== sig) {
                    sel.innerHTML = groups.map(function (g) {
                        return `<option value="${nodeChartEscape(g.key)}">${nodeChartEscape(g.label)}</option>`;
                    }).join('');
                    sel.dataset.sig = sig;
                }
                if (data.selectedKey)
                    sel.value = data.selectedKey;
                setInlineFlex(wrap, true);
            } else {
                setInlineFlex(wrap, false);
            }
        }

        function renderNodeChart(nodeId, data) {
            const graphId = `graph_node_${nodeId}`;
            const graphEl = document.getElementById(graphId);
            const noData = document.getElementById(`nodeChartNoData_${nodeId}`);
            const noteEl = document.getElementById(`nodeChartNote_${nodeId}`);
            const series = (data && data.series) || [];

            updateNodeChartTypes(nodeId, data);

            if (noteEl) {
                if (data && data.note) {
                    noteEl.textContent = data.note;
                    noteEl.classList.remove('d-none');
                } else {
                    noteEl.classList.add('d-none');
                }
            }

            if (!graphEl)
                return;

            if (!window.Plotly) {
                showNodeChartMessage(nodeId, 'Chart library failed to load');
                return;
            }

            if (series.length === 0) {
                showNodeChartMessage(nodeId, 'No data for the selected period');
                return;
            }

            if (noData)
                noData.classList.add('d-none');

            const unit = (data && data.unit) || '';
            const traces = series.map(function (s, i) {
                // Sensor names are user-influenced; escape before injecting into Plotly's pseudo-HTML text.
                const label = nodeChartEscape(s.label);
                return {
                    type: 'scattergl',
                    mode: 'lines',
                    name: label,
                    x: s.values.map(function (v) { return v.time; }),
                    y: s.values.map(function (v) { return v.value; }),
                    connectgaps: false,
                    line: { color: nodeChartPalette[i % nodeChartPalette.length], width: 1.5 },
                    hovertemplate: `${label}: %{y} ${unit}<br>%{x|%Y-%m-%d %H:%M:%S} UTC<extra></extra>`
                };
            });

            const layout = {
                autosize: true,
                margin: { l: 55, r: 20, t: 20, b: 40 },
                hovermode: 'closest',
                showlegend: true,
                legend: { orientation: 'h', x: 0, y: 1.08, yanchor: 'bottom' },
                xaxis: { type: 'date', autorange: true },
                yaxis: { title: { text: unit, font: { size: 12, color: '#7f7f7f' } }, autorange: true }
            };

            const config = {
                responsive: true,
                displaylogo: false,
                modeBarButtonsToRemove: ['lasso2d', 'select2d', 'autoScale2d']
            };

            window.Plotly.newPlot(graphId, traces, layout, config);
        }
    })();
</script>
