@using HSMServer.Constants
@using HSMServer.Controllers
@using HSMServer.Core.Model
@using HSMServer.Model.AlertSchedule

@model List<AlertScheduleViewModel>

@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<div class="container">
    <div class="row w-100 justify-content-center">
        <div class="m-2">
            <div class="d-flex justify-content-between my-2">
                <h5>Alert Schedules</h5>
                <div class='d-flex col-md-auto'>
                    <button id="addScheduleBtn" class="btn btn-link p-0">
                        <i class="fa-solid fa-plus"></i> Add Schedule
                    </button>
                </div>
            </div>

            <div id="alertSchedulesTableContainer">
                @await Html.PartialAsync("_AlertSchedulesTable", Model)
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_AlertScheduleModal")

<script>
    var scheduleUrls = {
        newPartial: '@Url.Action("NewPartial", "AlertSchedules")',
        editPartial: '@Url.Action("EditPartial", "AlertSchedules")',
        savePartial: '@Url.Action("SavePartial", "AlertSchedules")',
        getTable: '@Url.Action("GetAlertSchedulesTable", "AlertSchedules")'
    };
</script>

