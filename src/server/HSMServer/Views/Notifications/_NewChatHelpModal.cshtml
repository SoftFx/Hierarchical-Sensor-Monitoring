@using HSMServer.Constants
@using HSMServer.Controllers
@using HSMServer.Notifications
@using HSMServer.Model.Notifications
@using HSMServer.ServerConfiguration

@model NewChatHelpViewModel

@inject IServerConfig Config
@inject NotificationsCenter Notifications

@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    var botLinksClass = Notifications.TelegramBot.IsBotRunning ? string.Empty : "disabled-link";
    var botLinksTitle = Notifications.TelegramBot.IsBotRunning ? string.Empty : TelegramBot.BotIsNotRunningError;

    var isChatFlow = Model?.ChatId is { } chatId && chatId != Guid.Empty;
    var directAction = isChatFlow ? nameof(NotificationsController.OpenChatInvitationLink) : nameof(NotificationsController.OpenInvitationLink);
    var groupAction = isChatFlow ? nameof(NotificationsController.GetChatGroupInvitation) : nameof(NotificationsController.GetGroupInvitation);

    var routeValues = isChatFlow
        ? (object)new { chatId = Model.ChatId }
        : new { folderId = Model?.FolderId ?? Guid.Empty };

    var directLink = Url.Action(directAction, ViewConstants.NotificationsController, routeValues);
    var groupLink = Url.Action(groupAction, ViewConstants.NotificationsController, routeValues);
}


<div class="modal fade" tabindex="-1" role="dialog" id="newChatHelp_modal">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fab fa-telegram"></i> Telegram setup</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" onclick="hideAddChatHelpModal()" aria-label="Close"></button>
            </div>

            <div id="newChatHelp_modalBody" class="modal-body">
                <h6 class="mt-2">For group chat</h6>
                <p class="ms-2">
                    1. <a href='https://telegram.org/faq?setln=uz#q-how-do-i-create-a-group' target='_blank'>Create</a> group chat in Telegram. <br />
                    2. <a href='https://telegram.org/faq?setln=uz#q-how-do-i-add-more-members-what-39s-an-invite-link' target='_blank'>Add</a> Telegram Bot (@Config.Telegram.BotName) to group chat. <br />
                    3. <a href='https://telegram.org/faq?setln=uz#q-can-i-assign-administrators' target='_blank'>Give Admin right</a> to Telegram Bot (@Config.Telegram.BotName). <br />
                    4. Send <span title="@botLinksTitle"><a href="javascript:getGroupStartCommand()" class="@botLinksClass">this message</a></span> from clipboard to group chat.
                </p>

                <h6 class="mt-3">For direct chat</h6>
                <p class="ms-2">
                    Click <span title="@botLinksTitle"><a href="@directLink" target="_blank" class="@botLinksClass">invitation link</a></span> and press <b>Start</b> button at opened direct chat with Telegram Bot (@Config.Telegram.BotName).
                </p>
            </div>
        </div>
    </div>
</div>


<script>
    function showAddChatHelpModal() {
        $(`#newChatHelp_modal`).modal({
            backdrop: 'static'
        });
        $(`#newChatHelp_modal`).modal('show');
    }

    function hideAddChatHelpModal() {
        $(`#newChatHelp_modal`).modal('hide');
    }

    function getGroupStartCommand() {
        $.ajax({
            type: 'GET',
            url: `@Html.Raw(groupLink)`,
            dataType: 'html',
            contentType: 'application/json',
            cache: false,
            async: true
        }).done(function (command) {
            copyToClipboard(command);
        });
    }
</script>
