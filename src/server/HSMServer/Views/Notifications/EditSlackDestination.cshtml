@using HSMServer.Constants
@using HSMServer.Controllers
@using HSMServer.Extensions
@using HSMCommon.Extensions
@using HSMServer.Model.Notifications

@model SlackDestinationViewModel

@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = Model.Id == Guid.Empty ? "New Slack destination" : $"Slack destination {Model.Name}";

    var isNew = Model.Id == Guid.Empty;
    var action = isNew ? nameof(NotificationsController.AddSlackDestination) : nameof(NotificationsController.EditSlackDestination);
}


<div class="container">
    <div class="row w-100 justify-content-center">
        <div class="d-flex justify-content-between my-3 p-0">
            <h5 class="text-break">@(isNew ? "Add Slack destination" : $"Edit Slack destination '{Model.Name}'")</h5>

            @if (!isNew)
            {
                <a href="javascript:removeSlackDestination();">
                    <i class='fas fa-trash-alt'></i> Remove
                </a>
            }
        </div>

        <form id="slackDestination_form" class="my-2" method="post" asp-action="@action">
            <input asp-for="@Model.Id" value="@Model.Id" type="hidden" />

            <div class="row mt-2 mb-1">
                <div class="col-10 p-0">
                    <button class="btn btn-link text-decoration-none p-0 mb-1" type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#slackWebhookHelp"
                            aria-expanded="false"
                            aria-controls="slackWebhookHelp">
                        <i class="fa-solid fa-circle-info me-1"></i>
                        How to create a Slack incoming-webhook
                    </button>
                    <div id="slackWebhookHelp" class="collapse">
                        <div class="card card-body p-2 ps-3">
                            <ol class="mb-0">
                                <li>
                                    You must be a Slack workspace admin (or hold an app-install grant)
                                    to install incoming-webhooks.
                                </li>
                                <li>
                                    Create a custom app at
                                    <a href="https://api.slack.com/apps" target="_blank" rel="noopener noreferrer">api.slack.com/apps</a>,
                                    open <b>Incoming Webhooks</b>, and activate the feature.
                                    Prefer this over the legacy "Build Your Own" integration so one app
                                    can host multiple webhooks.
                                </li>
                                <li>
                                    Pick the target channel. <b>The webhook is bound to one channel</b>
                                    at creation time — HSM only sends <code>&#123;&quot;text&quot;:&quot;&hellip;&quot;&#125;</code>
                                    and cannot redirect it. To deliver to multiple channels, create one
                                    destination per channel.
                                </li>
                                <li>
                                    Copy the <code>https://hooks.slack.com/services/T&hellip;/B&hellip;/&lt;token&gt;</code>
                                    URL and paste it into the <b>Webhook URL</b> field below.
                                </li>
                                <li>
                                    Optional: customize the bot name and icon in the Slack app's
                                    <b>App Display</b> settings — HSM does not override them.
                                </li>
                                <li>
                                    After saving, use the <b>Send test message</b> action in the
                                    Slack destinations list to confirm delivery.
                                </li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-2">
                <div class="col-2 d-flex align-items-center">
                    <label class="col-form-label" asp-for="Name"></label>
                </div>
                <div class="col-8 p-0">
                    <input type="text" class="form-control" asp-for="Name" value="@Model.Name" required />
                    <span validation-for="Name" class="text-danger"></span>
                </div>
            </div>

            <div class="row mt-2">
                <div class="col-2 d-flex align-items-center">
                    <label class="col-form-label" asp-for="WebhookUrl"></label>
                    <i class='fas fa-question-circle ms-2' title='Slack incoming-webhook URL (https://hooks.slack.com/services/…). See “How to create a Slack incoming-webhook” below.'></i>
                </div>
                <div class="col-8 p-0">
                    <input type="url" class="form-control" asp-for="WebhookUrl" value="@Model.WebhookUrl" required placeholder="https://hooks.slack.com/services/..." />
                    <span validation-for="WebhookUrl" class="text-danger"></span>
                </div>
            </div>

            <div class="row mt-2">
                <div class="col-2 d-flex align-items-center">
                    <label class="col-form-label" asp-for="Description"></label>
                </div>
                <div class="col-8 p-0">
                    <input type="text" class="form-control" asp-for="Description" value="@Model.Description" />
                </div>
            </div>

            <div class="row mt-2">
                <div class="col-2 d-flex align-items-center">
                    <label class="col-form-label" asp-for="EnableMessages"></label>
                    <i class='fas fa-question-circle ms-2' title='Uncheck to temporarily mute this destination without removing it.'></i>
                </div>
                <div class="col-4 form-check form-switch mt-2">
                    <input id="enable-messages" class="form-check-input" type="checkbox" asp-for="EnableMessages" checked="@Model.EnableMessages">
                </div>
            </div>

            <div class="row mt-2">
                <div class="col-2 d-flex align-items-center">
                    <label class="col-form-label" asp-for="MessagesDelay"></label>
                    <i class='fas fa-question-circle ms-2' title='Alert notifications aggregation period in seconds. Set 0 for immediate delivery.'></i>
                </div>
                <div class="col-4 p-0">
                    <div class="input-group">
                        <input type="number" class="form-control" asp-for="MessagesDelay" min="0">
                        <span class="input-group-text">sec</span>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end my-2">
                <a href="@Url.Action(nameof(ConfigurationController.Index), ViewConstants.ConfigurationController)"
                   class="btn btn-link my-1 me-2">Cancel</a>
                <button type="submit" class="btn btn-primary independentSizeButton my-1">Save</button>
            </div>

            @if (!isNew)
            {
                <partial name="_ChatFolders" for="Folders" />
            }
        </form>
    </div>
</div>

@await Html.PartialAsync("~/Views/Shared/_ConfirmationModal.cshtml")


<script>
    function removeSlackDestination() {
        const destinationName = @Json.Serialize(Model.Name);
        showConfirmationModal(
            `Removing Slack destination '${destinationName}'`,
            `Do you really want to remove Slack destination '${destinationName}'? Alerts targeting it will no longer fire Slack delivery.`,
            function () {
                $.ajax({
                    type: 'POST',
                    url: `@Url.Action(nameof(NotificationsController.RemoveSlackDestination), ViewConstants.NotificationsController)?id=@Model.Id`,
                    cache: false,
                    async: true,
                    success: function () {
                        window.location.href = `@Url.Action(nameof(ConfigurationController.Index), ViewConstants.ConfigurationController)`;
                    }
                });
            }
        );
    }
</script>
