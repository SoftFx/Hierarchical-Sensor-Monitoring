@using HSMCommon.Model
@using HSMServer.Constants
@using HSMServer.Controllers
@using HSMServer.Core.Model
@using HSMServer.Helpers
@using HSMServer.Model.DataAlerts
@using HSMServer.Model.DataAlertTemplates


@model DataAlertTemplateViewModel

@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Alert Templates";
    Layout = "~/Views/Tree/_Layout.cshtml";

    const byte ttlType = TimeToLiveAlertViewModel.AlertKey;
    var hasAlerts = Model.DataAlerts.Any(a => a.Value.Any(v => v.IsAlertDisplayed));
}

<div class="container">
    <div class="row w-100 justify-content-center">
        <div class="m-2">
            @await Html.PartialAsync("_AlertTemplate", Model)
        </div>
    </div>
</div>

<script>
    $(document).ready(function() {
        initForm();
        if(getPaths().length > 0 && getPaths().some(p => p !== ''))
            updateForm(@(Model.IsNew.ToString().ToLower()));
    });

    function initForm(){
        $('#Type').off("change").on("change", function() {
            onSensorTypeChanged();
        });

        $("#submit_form").off('click').on('click', function () {
            submitForm();
        });

        $("#FolderId").off('click').on('click', function () {
            updateForm(false);
        });

        // Path template input events (debounced)
        let timeout = null;
        $('#pathTemplatesContainer').on("input", ".path-template-input", function() {
            clearTimeout(timeout);
            timeout = setTimeout(() => {
                updateForm();
            }, 500);
        });

        // Add path button
        $('#addPathBtn').off('click').on('click', function() {
            addPathInput();
        });

        // Remove path buttons
        $('#pathTemplatesContainer').on('click', '.remove-path-btn', function() {
            var $row = $(this).closest('.path-template-row');
            var pathValue = $row.find('.path-template-input').val();
            if (pathValue && pathValue.trim() !== '') {
                showConfirmationModal(
                    'Remove path',
                    'Remove this path?',
                    function() {
                        $row.remove();
                        reindexPathInputs();
                        updateRemoveButtons();
                        updateForm();
                    }
                );
                return;
            }

            $row.remove();
            reindexPathInputs();
            updateRemoveButtons();
            updateForm();
        });

        updateRemoveButtons();

        // Pagination click handler (delegated)
        $('#sensors_pagination').off('click').on('click', '.page-link', function(e) {
            e.preventDefault();
            var page = $(this).data('page');
            if (page)
                updateForm(false, page);
        });
    }

    function addPathInput() {
        var container = $('#pathTemplatesContainer');
        var index = container.find('.path-template-row').length;
        var newRow = $(
            '<div class="d-flex align-items-center mb-1 path-template-row">' +
            '<input type="text" class="form-control path-template-input" name="PathTemplates[' + index + ']" placeholder="Example: {product}/.computer/*/Free space on {diskName} disk" value="" />' +
            '<button type="button" class="btn btn-link remove-path-btn p-0 ms-1"><i class="fa-solid fa-xmark"></i></button>' +
            '</div>'
        );
        container.append(newRow);
        updateRemoveButtons();
        newRow.find('.path-template-input').focus();
    }

    function reindexPathInputs() {
        $('#pathTemplatesContainer .path-template-row').each(function(i) {
            $(this).find('.path-template-input').attr('name', 'PathTemplates[' + i + ']');
        });
    }

    function updateRemoveButtons() {
        var rows = $('#pathTemplatesContainer .path-template-row');
        rows.each(function() {
            $(this).find('.remove-path-btn').toggle(rows.length > 1);
        });
    }

    function getPaths() {
        return $('#pathTemplatesContainer .path-template-input').map(function() {
            return $(this).val();
        }).get();
    }

    function onSensorTypeChanged(needUpdateForm = true) {

        if(needUpdateForm)
            updateForm(false);

        var val = $('#Type').val();

        // Rename the unified alerts container to track the current type. For Any templates
        // the container is keyed by ttlType (only TTL alerts are addable).
        var listType = val == @DataAlertTemplateViewModel.AnyType ? @ttlType : val;

        $("[id^='dataAlertsList_']").each(function () {
            var currentId = $(this).attr('id');
            var currentType = currentId.replace('dataAlertsList_', '');
            if (currentType != listType) {
                $(this).empty();
                $(this).attr('id', 'dataAlertsList_' + listType);
            }
        });
    }

    function addDataAlert(entityId) {
        // For Type=Any templates, only TTL alerts are addable (regular alerts need a concrete type).
        // For concrete types, a regular alert is created and the user can switch the property
        // to Inactivity Period in the condition block.
        var selectedType = $('#Type').val();
        var isAny = selectedType == @DataAlertTemplateViewModel.AnyType;
        var listType = isAny ? @ttlType : selectedType;
        var sendType = isAny ? @ttlType : selectedType;

        $.ajax({
            url: `@Url.Action(nameof(HomeController.AddDataPolicy), ViewConstants.HomeController)?type=${sendType}&entityId=${entityId}&folderId=${$('#FolderId').val()}`,
            cache: false
        }).done(function (viewData) {
            $(`#dataAlertsList_${listType}`).append(viewData);
        });
    }

    function submitForm() {
        let form = document.getElementById('addAlertTemplate_form');
        var formData = new FormData(form);
        collectAlerts(formData);

        $.ajax({
            url: $("#addAlertTemplate_form").attr("action"),
            type: $("#addAlertTemplate_form").attr("method"),
            data: formData,
            processData: false,
            contentType: false,
            async: true,
            success: (viewData) => {
                if (!viewData){
                    window.location.href = '@Html.Raw(Url.Action(nameof(AlertTemplatesController.Index), ViewConstants.AlertTemplatesController))';
                }
                else if (typeof viewData === 'object' && viewData.success === false) {
                    showConfirmationModal(
                        'Failed to save template',
                        viewData.error,
                        () => {},
                        () => { window.location.href = '@Html.Raw(Url.Action(nameof(AlertTemplatesController.Index), ViewConstants.AlertTemplatesController))'; },
                        'Edit',
                        'Discard'
                    );
                }
                else {
                    $("#addAlertTemplate_form").html(viewData);
                    initForm();
                }
            }
        });
    }

    function updateForm(needChangeType = true, page = 1) {
        var type = $('#Type').val();
        var paths = getPaths().filter(p => p !== '');
        var folderId = $('#FolderId').val();

        $.ajax({
            url: '@Url.Action(nameof(AlertTemplatesController.UpdateTemplate), ViewConstants.AlertTemplatesController)',
            data: { type: type, paths: JSON.stringify(paths), folderId: folderId, page: page },
            cache: false,
            success: (viewData) => {

                var data = JSON.parse(viewData);

                if (needChangeType & data['Type'] != null) {
                    $('#Type').val(data['Type']);
                    onSensorTypeChanged(false);
                }

                if (data['Sensors'] != null) {
                    $('#affected_sensors_cardbody').empty();
                    $('#affected_sensors_cardbody').append(data['Sensors']);
                    $('#affected_sensors').removeClass('d-none');
                    renderSensorsPagination(data['Page'], data['TotalPages']);
                }
                else {
                    $('#affected_sensors_cardbody').empty();
                    $('#affected_sensors_cardbody').html("No sensors were found along the specified path.");
                    $('#affected_sensors').removeClass('d-none');
                    $('#sensors_pagination').addClass('d-none');
                }

                if (data['Chats'] != null) {
                    updateTemplateChatDropdowns(data['Chats']);
                }
            }
        });
    }

    function collectAlerts(formData) {
        $("[id^='dataAlertsList_']").each(function () {
            const type = this.id.substring("dataAlertsList_".length, this.id.length);

            setFormDataAlerts(formData, type, $(this));
        });
    }

    function setFormDataAlerts(formData, type, alertsList) {
        // Per-row destination type: read data-alert-type if present (set in _DataAlert.cshtml
        // based on whether the main condition is TTL). Rows whose main condition is TTL route
        // to DataAlerts[255] so the server stores them as TTLPolicy; others go to the
        // container's sensor type. Indices are tracked per destination type so the ASP.NET
        // model binder sees contiguous indexes for each key.
        const ttlKey = String(@ttlType);
        let counters = {};
        counters[type] = 0;
        counters[ttlKey] = 0;

        alertsList.find(`div.dataAlertRow`).each(function () {
            const $row = $(this);
            const rawType = $row.data("alert-type");
            const alertType = rawType != null ? String(rawType) : String(type);
            if (!(alertType in counters)) counters[alertType] = 0;
            const i = counters[alertType]++;

            setFormDataAlertsProperty(formData, "input", alertType, i, $row, "Id");
            setFormDataAlertsProperty(formData, "input", alertType, i, $row, "EntityId");
            setFormDataAlertsProperty(formData, "input", alertType, i, $row, "IsDisabled");
            setFormDataAlertsProperty(formData, "input", alertType, i, $row, "TemplateId");
            setFormDataAlertsProperty(formData, "select", alertType, i, $row, "ScheduleId");


            $row.find(`div[name='alertCondition']`).each(function (j) {
                setFormDataAlertsListProperty(formData, alertType, i, j, $(this), "Conditions", "select", "Property");

                let intervalOperationBlock = $(this).find('div.interval-operation');
                if (intervalOperationBlock.hasClass("d-flex")) {
                    setFormDataAlertsConditionIntervals(formData, alertType, i, j, intervalOperationBlock, "select", "Interval");
                    setFormDataAlertsConditionIntervals(formData, alertType, i, j, intervalOperationBlock, "input", "CustomString");
                }
                else {
                    let operationBlock = $(this).find('div.operation');

                    setFormDataAlertsListProperty(formData, alertType, i, j, operationBlock, "Conditions", "select", "Operation");
                    setFormDataAlertsListProperty(formData, alertType, i, j, operationBlock, "Conditions", "input", "Target");
                }
            });

            $row.find(`div[name='alertAction']`).each(function (j) {
                setFormDataAlertsListProperty(formData, alertType, i, j, $(this), "Actions", "select", "Action");

                let sendBlock = $(this).find('div[name="sendNotificationAction"]');
                if (sendBlock.hasClass('d-flex')) {
                    setFormDataAlertsListProperty(formData, alertType, i, j, sendBlock, "Actions", "input", "Comment");
                    setFormDataAlertsSendNotificationChats(formData, alertType, i, j, sendBlock);

                    let scheduleBlock = sendBlock.find('div[name="schedule"]');
                    if (scheduleBlock.hasClass('d-flex')) {
                        setFormDataAlertsListProperty(formData, alertType, i, j, scheduleBlock, "Actions", "select", "ScheduleRepeatMode");

                        // TTL alerts only support repeat-mode scheduling. StartTime/InstantSend
                        // are not rendered for TTL rows loaded from storage (Model.IsTtl gate in
                        // _ActionBlock.cshtml); for rows promoted to TTL client-side the inputs
                        // exist but are disabled+hidden via the .ttlAction class. Skip both
                        // fields when routing to the TTL key so the server doesn't receive
                        // leftover values from a regular→TTL toggle.
                        if (alertType !== ttlKey) {
                            setFormDataAlertsListProperty(formData, alertType, i, j, scheduleBlock, "Actions", "input", "ScheduleStartTime");
                            setFormDataAlertsListProperty(formData, alertType, i, j, scheduleBlock, "Actions", "input", "ScheduleInstantSend", 'checkbox');
                        }
                    }
                }

                let showBlock = $(this).find('div[name="showIconAction"]');
                if (showBlock.hasClass('d-flex')) {
                    showBlock.find(`div[name='emoji']`).each(function () {
                        formData.append(`DataAlerts[${alertType}][${i}].Actions[${j}].Icon`, $(this)[0].innerText);
                    });
                }
            });
        });
    }

    function setFormDataAlertsProperty(formData, element, type, i, block, propertyName) {
        block.find(`${element}[name='${propertyName}']:first`).each(function () {
            formData.append(`DataAlerts[${type}][${i}].${propertyName}`, $(this).val());
        });
    }

    function setFormDataAlertsListProperty(formData, type, i, j, block, list, element, propertyName, elementType = undefined) {
        block.find(`${element}[name='${propertyName}']`).each(function () {
            let value = $(this).val();
            if (elementType == 'checkbox') {
                value = this.checked;
            }

            formData.append(`DataAlerts[${type}][${i}].${list}[${j}].${propertyName}`, value);
        });
    }

    function setFormDataAlertsConditionIntervals(formData, type, i, j, block, element, propertyName) {
        var targetName = block.attr("name");

        block.find(`${element}[name='Target.${propertyName}']`).each(function () {
            formData.append(`DataAlerts[${type}][${i}].Conditions[${j}].${targetName}.${propertyName}`, $(this).val());
        });
    }

    function setFormDataAlertsSendNotificationChats(formData, type, i, j, block) {
        let chatsMode = '@ChatsMode.Custom';
        let chats = [];

        block.find("select[name='Chats']:first option").each(function () {
            if ($(this).is(':selected')) {
                if ($(this).val() === '@ChatsMode.FromParent' || $(this).val() === '@ChatsMode.NotInitialized' ||
                    $(this).val() === '@ChatsMode.Empty' || $(this).val() === '@ChatsMode.All') {
                    chatsMode = $(this).val();
                    chats = [];
                    return;
                }

                chats.push($(this).val());
            }
        });

        block.find("div[name='Chats']").each(function () {
            chatsMode = '@ChatsMode.FromParent';
        });

        formData.append(`DataAlerts[${type}][${i}].Actions[${j}].ChatsMode`, chatsMode);

        for (let k = 0; k < chats.length; ++k){
            formData.append(`DataAlerts[${type}][${i}].Actions[${j}].Chats[${k}]`, chats[k]);
        }
    }

    function updateTemplateChatDropdowns(chats) {
        var groups = chats.filter(c => c.Type === 1);
        var users = chats.filter(c => c.Type === 0);

        $('form#addAlertTemplate_form select[name="Chats"]').each(function() {
            var $select = $(this);
            var currentSelected = ($select.val() || []).slice();

            $select.find('option').not('.general-group-chat-mode').remove();

            $select.append('<option data-divider="true"></option>');
            $select.append('<option disabled>Groups</option>');
            groups.forEach(function(chat) {
                var isSelected = currentSelected.includes(chat.Id);
                $select.append(`<option value="${chat.Id}" ${isSelected ? 'selected' : ''}>${chat.Name}</option>`);
            });

            $select.append('<option data-divider="true"></option>');
            $select.append('<option disabled>Users</option>');
            users.forEach(function(chat) {
                var isSelected = currentSelected.includes(chat.Id);
                $select.append(`<option value="${chat.Id}" ${isSelected ? 'selected' : ''}>${chat.Name}</option>`);
            });

            $select.selectpicker('refresh');
        });
    }

    function renderSensorsPagination(currentPage, totalPages) {
        var $nav = $('#sensors_pagination');
        var $ul = $nav.find('ul');
        $ul.empty();

        if (totalPages <= 1) {
            $nav.addClass('d-none');
            return;
        }

        $nav.removeClass('d-none');

        // Previous
        if (currentPage > 1)
            $ul.append('<li class="page-item"><a class="page-link" href="#" data-page="' + (currentPage - 1) + '">&laquo;</a></li>');
        else
            $ul.append('<li class="page-item disabled"><span class="page-link">&laquo;</span></li>');

        // Page window (show up to 5 pages around current)
        var startPage = Math.max(1, currentPage - 2);
        var endPage = Math.min(totalPages, startPage + 4);
        if (endPage - startPage < 4)
            startPage = Math.max(1, endPage - 4);

        if (startPage > 1) {
            $ul.append('<li class="page-item"><a class="page-link" href="#" data-page="1">1</a></li>');
            if (startPage > 2)
                $ul.append('<li class="page-item disabled"><span class="page-link">...</span></li>');
        }

        for (var i = startPage; i <= endPage; i++) {
            if (i === currentPage)
                $ul.append('<li class="page-item active"><span class="page-link">' + i + '</span></li>');
            else
                $ul.append('<li class="page-item"><a class="page-link" href="#" data-page="' + i + '">' + i + '</a></li>');
        }

        if (endPage < totalPages) {
            if (endPage < totalPages - 1)
                $ul.append('<li class="page-item disabled"><span class="page-link">...</span></li>');
            $ul.append('<li class="page-item"><a class="page-link" href="#" data-page="' + totalPages + '">' + totalPages + '</a></li>');
        }

        // Next
        if (currentPage < totalPages)
            $ul.append('<li class="page-item"><a class="page-link" href="#" data-page="' + (currentPage + 1) + '">&raquo;</a></li>');
        else
            $ul.append('<li class="page-item disabled"><span class="page-link">&raquo;</span></li>');
    }

</script>
