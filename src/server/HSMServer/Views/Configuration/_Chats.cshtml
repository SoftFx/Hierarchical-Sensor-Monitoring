@using HSMServer.Controllers
@using HSMServer.Constants
@using HSMServer.Extensions
@using HSMServer.Model.Configuration
@using HSMServer.Model.ViewModel

@model ChatsSettingsViewModel

@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers


<div class="d-flex justify-content-between my-2">
    <h5 class="m-0">Notification chats</h5>
    <div class='d-flex col-md-auto'>
        <a href="@Url.Action(nameof(NotificationsController.AddChat), ViewConstants.NotificationsController)"
           class="btn btn-link p-0">
            <i class="fa-solid fa-plus"></i> Add new chat
        </a>
    </div>
</div>

@if (Model.Chats is null || Model.Chats.Count == 0)
{
    <div class="text-muted">No chats configured yet.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Channels</th>
                <th class="text-center">Enabled</th>
                <th>Author</th>
                <th>Created</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var chat in Model.Chats)
            {
                <tr>
                    <td>@chat.Name</td>
                    <td>@Html.Raw(chat.ChatBrandIcons())</td>
                    <td class="text-center">
                        @if (chat.EnableMessages)
                        {
                            <i class="fa-solid fa-check fa-lg text-success"></i>
                        }
                    </td>
                    <td>@(chat.Author ?? "—")</td>
                    <td>@chat.CreationDate.ToLocalTime().ToString("g")</td>
                    <td nowrap class="text-center w-10">
                        <div class='btn-group'>
                            <button id="actionButton" class="btn" data-bs-toggle="dropdown" data-bs-auto-close="true" aria-haspopup="true" aria-expanded="false">
                                <i class="fa-solid fa-ellipsis-vertical" style="cursor: pointer"></i>
                            </button>
                            <ul class='dropdown-menu dropdown-menu-end overflow-auto' aria-labelledby="dropdownMenuButton">
                                <li>
                                    <a class='dropdown-item text-decoration-none fw-normal' style="cursor: pointer;"
                                       href="@Url.Action(nameof(NotificationsController.EditChat), ViewConstants.NotificationsController, new { id = chat.Id })">
                                        View/Edit
                                    </a>
                                </li>
                                @if (chat.HasTelegram)
                                {
                                    <li>
                                        <a id="sendTelegram_@chat.Id" data-telegram-chat-id="@chat.TelegramChatId" class='dropdown-item text-decoration-none fw-normal' style="cursor: pointer;">
                                            Send test Telegram message
                                        </a>
                                    </li>
                                }
                                @if (chat.HasSlack)
                                {
                                    <li>
                                        <a id="sendSlack_@chat.Id" class='dropdown-item text-decoration-none fw-normal' style="cursor: pointer;">
                                            Send test Slack message
                                        </a>
                                    </li>
                                }
                                <li>
                                    <a id='remove_@chat.Id' class='dropdown-item text-decoration-none fw-normal' style="cursor: pointer;">
                                        Remove
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<form id="removeChat_form" method="post"
      action="@Url.Action(nameof(NotificationsController.RemoveChat), ViewConstants.NotificationsController)">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="removeChat_id" />
</form>

<script>
    $(function () {
        $(document).off("click", "[id^=remove_]").on("click", "[id^=remove_]", function () {
            var id = this.id.substring("remove_".length, this.id.length);
            var row = $(this).closest('tr');
            var name = row.find('td:first').text().trim();

            if (!confirm("Remove chat \"" + name + "\"?"))
                return;

            $("#removeChat_id").val(id);
            $("#removeChat_form").submit();
        });

        $(document).off("click", "[id^=sendTelegram_]").on("click", "[id^=sendTelegram_]", function () {
            var chatId = $(this).data("telegram-chat-id");

            $.get("@Url.Action(nameof(NotificationsController.SendTestTelegramMessage), ViewConstants.NotificationsController)", { chatId: chatId })
                .done(function () { showToast("Test Telegram message sent."); })
                .fail(function () { showToast("Failed to send test Telegram message."); });
        });

        $(document).off("click", "[id^=sendSlack_]").on("click", "[id^=sendSlack_]", function () {
            var id = this.id.substring("sendSlack_".length, this.id.length);

            $.get("@Url.Action(nameof(NotificationsController.SendTestSlackMessage), ViewConstants.NotificationsController)", { id: id })
                .done(function () { showToast("Test Slack message sent."); })
                .fail(function () { showToast("Failed to send test Slack message."); });
        });
    });
</script>
