@using HSMServer.Controllers
@using HSMServer.Constants
@using HSMServer.Model.Configuration

@model SlackSettingsViewModel

@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers


<p class="mt-3">
    Each Slack destination is one incoming-webhook URL. Create a webhook in Slack
    (channel &rarr; Integrations &rarr; Incoming Webhook), then paste the URL here.
    Destinations are bound to folders from the folder's <b>Chats</b> tab and referenced
    from alert actions alongside Telegram chats.
</p>

<div class="d-flex justify-content-between my-2">
    <h5 class="m-0">Slack destinations</h5>
    <div class='d-flex col-md-auto'>
        <a href="@Url.Action(nameof(NotificationsController.EditSlackDestination), ViewConstants.NotificationsController, new { id = Guid.Empty })"
           class="btn btn-link p-0">
            <i class="fa-solid fa-plus"></i> Add new destination
        </a>
    </div>
</div>

@if (Model.Destinations is null || Model.Destinations.Count == 0)
{
    <div class="text-muted">No Slack destinations configured yet.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Webhook URL</th>
                <th class="text-center">Enabled</th>
                <th>Author</th>
                <th>Created</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model.Destinations)
            {
                <tr>
                    <td>@d.Name</td>
                    <td><code>@MaskUrl(d.WebhookUrl)</code></td>
                    <td class="text-center">
                        @if (d.EnableMessages)
                        {
                            <i class="fa-solid fa-check fa-lg text-success"></i>
                        }
                    </td>
                    <td>@(d.Author ?? "—")</td>
                    <td>@d.CreationDate.ToLocalTime().ToString("g")</td>
                    <td nowrap class="text-center w-10">
                        <div class='btn-group'>
                            <button id="actionButton" class="btn" data-bs-toggle="dropdown" data-bs-auto-close="true" aria-haspopup="true" aria-expanded="false">
                                <i class="fa-solid fa-ellipsis-vertical" style="cursor: pointer"></i>
                            </button>
                            <ul class='dropdown-menu dropdown-menu-end overflow-auto' aria-labelledby="dropdownMenuButton">
                                <li>
                                    <a class='dropdown-item text-decoration-none fw-normal' style="cursor: pointer;"
                                       href="@Url.Action(nameof(NotificationsController.EditSlackDestination), ViewConstants.NotificationsController, new { id = d.Id })">
                                        View/Edit
                                    </a>
                                </li>
                                <li>
                                    <a id="sendMessage_@d.Id" class='dropdown-item text-decoration-none fw-normal' style="cursor: pointer;">
                                        Send test message
                                    </a>
                                </li>
                                <li>
                                    <a id='remove_@d.Id' class='dropdown-item text-decoration-none fw-normal' style="cursor: pointer;">
                                        Remove
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<form id="removeSlackDestination_form" method="post"
      action="@Url.Action(nameof(NotificationsController.RemoveSlackDestination), ViewConstants.NotificationsController)">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="removeSlackDestination_id" />
</form>

<script>
    $(function () {
        $(document).off("click", "[id^=remove_]").on("click", "[id^=remove_]", function () {
            var id = this.id.substring("remove_".length, this.id.length);
            var row = $(this).closest('tr');
            var name = row.find('td:first').text().trim();

            if (!confirm("Remove Slack destination \"" + name + "\"?"))
                return;

            $("#removeSlackDestination_id").val(id);
            $("#removeSlackDestination_form").submit();
        });

        $(document).off("click", "[id^=sendMessage_]").on("click", "[id^=sendMessage_]", function () {
            var id = this.id.substring("sendMessage_".length, this.id.length);

            $.ajax({
                url: `@Url.Action(nameof(NotificationsController.SendTestSlackMessage), ViewConstants.NotificationsController)?id=${id}`
            }).done(function () {
                showToast("Test message sent.");
            });
        });
    });
</script>

@{
    static string MaskUrl(string url)
    {
        if (string.IsNullOrEmpty(url) || url.Length <= 24)
            return url;

        return url[..24] + "…";
    }
}
