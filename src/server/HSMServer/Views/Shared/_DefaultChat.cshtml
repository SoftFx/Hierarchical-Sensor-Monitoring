@using HSMCommon.Extensions
@using HSMServer.Model.Controls
@using HSMServer.Notifications
@using HSMServer.Notifications.Chats
@using HSMServer.Extensions

@model DefaultChatViewModel

@inject IChatsManager ChatsManager

@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    var available = new Dictionary<Guid, string>();
    foreach (var chat in ChatsManager.GetValues())
        available[chat.Id] = chat.Name;

    var (displayName, parentChats) = Model.GetDisplayChatName(available, out var allChats);

    var availableChats = ChatsManager.GetValues().Where(c => allChats.ContainsKey(c.Id)).OrderBy(c => c.Name).ToList();
}


<span class="@(Model.IsModify ? "col-2" : "meta-info-label")">Chat(s)</span>

<span id="labelDefaultChat" class="@(Model.IsModify ? "d-none" : "meta-info-value")">
    @if (Model.IsNotInitialized || Model.IsEmpty || (Model.IsFromParent && Model.SelectedChats.Count == 0))
    {
        @displayName
    }
    else
    {
        if (Model.IsFromParent)
        {
            <span>@parentChats</span>
            if (Model.SelectedChats.Count > 0)
            {
                <span>, </span>
            }
        }

        var first = true;
        foreach (var id in Model.SelectedChats)
        {
            if (!first) { <span>, </span> }
            first = false;

            Chat chat = null;
            ChatsManager.TryGetValue(id, out chat);
            var icon = chat?.ChatBrandIcons() ?? string.Empty;
            if (!string.IsNullOrEmpty(icon)) { @Html.Raw(icon) }

            if (allChats.TryGetValue(id, out var name)) { <span>@name</span> }
            else { <span>@id</span> }
        }
    }
</span>
<div id="defaultChatControl" class="@(Model.IsModify ? "col-auto ms-1 mx-2" : "d-none meta-info-interval mx-2")">
    <select name="SelectedChats" class="default-chat selectpicker" multiple data-live-search="true" data-placeholder="Default chat(s)" required>
        <option value="@DefaultChatMode.FromParent" selected="@Model.IsSelectedMode(DefaultChatMode.FromParent)">@parentChats</option>
        <option value="@DefaultChatMode.NotInitialized" selected="@Model.IsSelectedMode(DefaultChatMode.NotInitialized)">@DefaultChatMode.NotInitialized.GetDisplayName()</option>
        <option value="@DefaultChatMode.Empty" selected="@Model.IsSelectedMode(DefaultChatMode.Empty)">@DefaultChatMode.Empty.GetDisplayName()</option>

        @if (availableChats.Count > 0)
        {
            <option data-divider="true"></option>
            foreach (var chat in availableChats)
            {
                <option value="@chat.Id" selected="@Model.IsSelectedChat(chat.Id)" data-content="@chat.ChatBrandIconsAndName()">@chat.Name</option>
            }
        }
    </select>
</div>

<i class='fas fa-question-circle mx-2' title='Chat that will be default for new sensors.'></i>


<script>
    $(document).ready(function () {
        $("select[name='SelectedChats']").selectpicker();
        $("select[name='SelectedChats']").off('changed.bs.select').on('changed.bs.select', function (e, clickedIndex, isSelected, previousValue, a) {
            const clickedValue = $(this)[0].options[clickedIndex].value;
            if ((clickedValue === 'Empty' || clickedValue === 'NotInitialized') && isSelected) {
                $(this).val($(this)[0].options[clickedIndex].value);
            }
            else {
                if (Array.from($("select[name='SelectedChats']")[0].selectedOptions).find(x => x.value === 'NotInitialized' || x.value === 'Empty') !== undefined)
                    $(this).val($(this)[0].options[clickedIndex].value);
            }

            $(this).selectpicker('refresh')
        });
    })

    function fillDefaultChatMode(formData) {
        let chatsMode = '@DefaultChatMode.Custom';
        let chats = [];

        $(document).find("select[name='SelectedChats']:first option").each(function () {
            if ($(this).is(':selected')) {
                if ($(this).val() === '@DefaultChatMode.FromParent' || $(this).val() === '@DefaultChatMode.NotInitialized' ||
                    $(this).val() === '@DefaultChatMode.Empty') {
                    chatsMode = $(this).val();
                    chats = [];
                    return;
                }

                chats.push($(this).val());
            }
        });

        formData.append(`DefaultChats.ChatMode`, chatsMode);

        for (let k = 0; k < chats.length; ++k) {
            formData.append(`DefaultChats.SelectedChats[${k}]`, chats[k]);
        }
    }
</script>
