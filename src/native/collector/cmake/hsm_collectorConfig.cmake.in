@PACKAGE_INIT@

# find_package(hsm_collector) config (#1100). Re-resolves the public link dependencies of
# hsm_collector_core, then pulls in the exported targets:
#   hsm_collector::hsm_collector_core  (static core + C ABI)
#   hsm_collector::hsm_collector_cpp   (header-only C++ RAII wrapper; links the core)

include(CMakeFindDependencyMacro)

find_dependency(Threads)

# CURL is a PUBLIC dependency only when the library was built with the HTTP transport
# (HSM_COLLECTOR_HTTP). The value is baked in at configure time.
if(@HSM_COLLECTOR_HTTP@)
    find_dependency(CURL)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/hsm_collectorTargets.cmake")

check_required_components(hsm_collector)
