# HSM collector conformance — bar sensor full registration surface (BarSensorOptions parity).
# create_double_bar_sensor_full_options|path|bar_period|post_period|precision|ttl_ms|unit|display_unit|
#     keep_history_ms|self_destroy_ms|statistics|is_singleton|aggregate|grafana|is_computer|
#     sensor_location|description[|default_alert_options]
#   tri-state (is_singleton/aggregate/grafana): -1 => null, 0 => false, 1 => true.
#   statistics: -1 => None(0), else StatisticsOptions flags (EMA=1). Ticks on the wire = ms * 10000.
#   display_unit: ALWAYS pass -1 — bars are SensorOptions<NoDisplayUnit> and register DisplayUnit:null.
#   default_alert_options (optional trailing): managed [Flags] DefaultAlertsOptions (DisableTtl=1,
#     DisableStatusChange=2). The server attaches default TTL + status-change alerts; these register
#     them disabled. Both drivers feed the SAME options through BarSensorOptions.ToApi() (managed) and
#     hsm_collector_create_double_bar_sensor_with_options (native) — substrings pin the byte-identical
#     bar registration.

bar_full_options_register_in_payload|create_collector
bar_full_options_register_in_payload|create_double_bar_sensor_full_options|contract/bar/full|300000|0|2|60000|1010|-1|600000|1200000|1|1|1|1|false|0|bar|3
bar_full_options_register_in_payload|start
bar_full_options_register_in_payload|stop
bar_full_options_register_in_payload|expect_registration_count|1
bar_full_options_register_in_payload|expect_registration_contains|0|"TTLTicks":[600000000]
bar_full_options_register_in_payload|expect_registration_contains|0|"OriginalUnit":1010,
bar_full_options_register_in_payload|expect_registration_contains|0|"KeepHistory":6000000000
bar_full_options_register_in_payload|expect_registration_contains|0|"SelfDestroy":12000000000
bar_full_options_register_in_payload|expect_registration_contains|0|"Statistics":1
bar_full_options_register_in_payload|expect_registration_contains|0|"DisplayUnit":null
bar_full_options_register_in_payload|expect_registration_contains|0|"IsSingletonSensor":true
bar_full_options_register_in_payload|expect_registration_contains|0|"AggregateData":true
bar_full_options_register_in_payload|expect_registration_contains|0|"EnableGrafana":true
bar_full_options_register_in_payload|expect_registration_contains|0|"Description":"bar"
bar_full_options_register_in_payload|expect_registration_contains|0|"DefaultAlertsOptions":3}

# Absent trailing field => DefaultAlertsOptions 0 (None); reproduces a plain bar otherwise.
bar_default_alerts_none|create_collector
bar_default_alerts_none|create_double_bar_sensor_full_options|contract/bar/da_none|300000|0|2|0|-1|-1|0|0|-1|-1|-1|-1|false|0|d
bar_default_alerts_none|start
bar_default_alerts_none|stop
bar_default_alerts_none|expect_registration_count|1
bar_default_alerts_none|expect_registration_contains|0|"DisplayUnit":null
bar_default_alerts_none|expect_registration_contains|0|"DefaultAlertsOptions":0}
