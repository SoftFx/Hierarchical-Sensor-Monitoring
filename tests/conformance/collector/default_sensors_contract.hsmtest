service_status_registers_enum_options|expect_registration_contains|0|"SensorType":10,
service_status_registers_enum_options|expect_registration_contains|0|"Key":4,"Value":"Running","Color":65280
service_status_registers_enum_options|expect_registration_contains|0|"Key":1,"Value":"Stopped","Color":16711680
service_status_registers_enum_options|expect_registration_contains|0|"ConfirmationPeriod":3000000000
service_status_registers_enum_options|expect_registration_contains|0|"AggregateData":true

# Module: collector alive — Bool, TTL alert (Conditions:null) -> TtlAlerts, TTLTicks [null], KeepHistory 180d.
collector_alive_registers_ttl_alert|create_collector
collector_alive_registers_ttl_alert|add_default_sensor|collector_alive
collector_alive_registers_ttl_alert|start
collector_alive_registers_ttl_alert|stop
