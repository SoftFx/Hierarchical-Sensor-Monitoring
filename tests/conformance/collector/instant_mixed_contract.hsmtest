# HSM collector instant sensor conformance for non-integer primitive types.

bool_true_payload|create_collector
bool_true_payload|create_bool_sensor|contract/instant/bool/true
bool_true_payload|start
bool_true_payload|add_bool|0|true|Ok|bool-true
bool_true_payload|expect_sent_count|1
bool_true_payload|expect_payload_contains|0|"Type":0
bool_true_payload|expect_payload_contains|0|"Value":true
bool_true_payload|expect_payload_contains|0|"Path":"conformance-host/conformance-module/contract/instant/bool/true"

bool_false_payload|create_collector
bool_false_payload|create_bool_sensor|contract/instant/bool/false
bool_false_payload|start
bool_false_payload|add_bool|0|false|Warning|bool-false
bool_false_payload|expect_sent_count|1
bool_false_payload|expect_payload_contains|0|"Type":0
bool_false_payload|expect_payload_contains|0|"Value":false
bool_false_payload|expect_payload_contains|0|"Status":2

